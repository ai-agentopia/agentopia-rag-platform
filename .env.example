# agentopia-rag-platform — Pipeline environment variables
# Copy to .env for local development. All vars are required unless marked optional.
# In Kubernetes, these are set via K8s Secrets (never hardcoded in manifests).

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
# Collection name: kb-{sha256(scope)[:16]}
# Pilot scope (joblogic-kb/api-docs): kb-1f28b6baebe4f76d
QDRANT_COLLECTION=kb-1f28b6baebe4f76d

# ── S3 source ────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=agentopia-rag-ingest
# Prefix convention: scopes/{client_id}/{scope_name}/
# Pilot scope prefix: scopes/joblogic-kb/api-docs/
S3_PREFIX=scopes/joblogic-kb/api-docs/
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=           # from K8s Secret in production
S3_SECRET_ACCESS_KEY=    # from K8s Secret in production

# ── Embedding ────────────────────────────────────────────────────────────────
# OpenAI-compatible endpoint. Set to OpenRouter or local model as needed.
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=       # from K8s Secret in production
EMBEDDING_MODEL=text-embedding-3-small

# ── Pathway runtime ──────────────────────────────────────────────────────────
# Poll interval: S3 is re-scanned every N seconds for new/changed/deleted objects
PATHWAY_POLL_INTERVAL_SECS=30
# Persistence state directory: mount a PVC at this path in K8s
PATHWAY_STATE_DIR=/var/pathway/state
